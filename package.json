{
  "name": "@butttons/draftboard",
  "type": "module",
  "version": "0.0.8",
  "bin": {
    "draftboard": "./dist/draftboard.cjs"
  },
  "files": [
    "bin",
    ".output",
    "dist"
  ],
  "imports": {
    "#/*": "./src/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/butttons/draftboard"
  },
  "scripts": {
    "dev": "portless draftboard.dev vite dev",
    "build": "vite build && pnpm run build:bin",
    "preview": "portless draftboard.preview vite preview",
    "start": "portless draftboard node .output/server/index.mjs",
    "test": "vitest run",
    "build:bin": "esbuild bin/draftboard.ts --bundle --platform=node --format=cjs --outfile=dist/draftboard.cjs.tmp && printf '#!/usr/bin/env node\\n' | cat - dist/draftboard.cjs.tmp > dist/draftboard.cjs && rm dist/draftboard.cjs.tmp && chmod +x dist/draftboard.cjs",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-result": "^2.8.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "lucide-react": "^1.8.0",
    "nitro": "^3.0.260415-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "portless": "^0.10.3",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
